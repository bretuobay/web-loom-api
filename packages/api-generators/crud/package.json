{
  "name": "@web-loom/api-generator-crud",
  "version": "0.1.0",
  "description": "CRUD generator for Web Loom API Framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/"
  },
  "keywords": [
    "webloom",
    "api",
    "generator",
    "crud"
  ],
  "license": "MIT",
  "dependencies": {
    "@web-loom/api-core": "*",
    "@web-loom/api-middleware-auth": "*",
    "drizzle-orm": "^0.38.4",
    "hono": "^4.6.20"
  },
  "devDependencies": {
    "@libsql/client": "^0.14.0",
    "@types/node": "^22.10.5",
    "drizzle-orm": "^0.38.4",
    "zod": "^4.3.6"
  }
}
