{
  "name": "@web-loom/api-generator-openapi",
  "version": "0.1.0",
  "description": "OpenAPI generator for Web Loom API Framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/"
  },
  "keywords": [
    "webloom",
    "api",
    "generator",
    "openapi"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@scalar/hono-api-reference": "^0.10.4",
    "@web-loom/api-core": "*",
    "@web-loom/api-shared": "*",
    "openapi-types": "^12.1.3",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "5.9.2",
    "vitest": "^2.1.8"
  }
}
