{
  "name": "@web-loom/api-middleware-rate-limit",
  "version": "0.1.0",
  "description": "Rate limiting middleware for Web Loom API Framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/"
  },
  "keywords": [
    "webloom",
    "api",
    "middleware",
    "rate-limit"
  ],
  "license": "MIT",
  "dependencies": {
    "@web-loom/api-core": "*",
    "@web-loom/api-shared": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5"
  }
}
