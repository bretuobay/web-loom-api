{
  "name": "@web-loom/api-cli",
  "version": "0.1.0",
  "description": "CLI tool for Web Loom API Framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "webloom": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "webloom",
    "api",
    "framework",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@web-loom/api-core": "*",
    "@web-loom/api-shared": "*",
    "@web-loom/api-generator-openapi": "*",
    "@web-loom/api-generator-client": "*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "ora": "^8.1.1",
    "prompts": "^2.4.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "typescript": "5.9.2",
    "vitest": "^2.1.8"
  }
}
