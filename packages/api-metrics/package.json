{
  "name": "@web-loom/api-metrics",
  "version": "0.1.0",
  "description": "Prometheus-compatible metrics collection for Web Loom API Framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/"
  },
  "keywords": [
    "webloom",
    "webloom-metrics",
    "api",
    "prometheus",
    "observability"
  ],
  "license": "MIT",
  "dependencies": {
    "@web-loom/api-shared": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5"
  }
}
