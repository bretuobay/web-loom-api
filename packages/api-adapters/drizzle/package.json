{
  "name": "@web-loom/api-adapter-drizzle",
  "version": "0.1.0",
  "description": "Drizzle adapter for Web Loom API Framework",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "webloom",
    "api",
    "adapter",
    "drizzle",
    "database"
  ],
  "license": "MIT",
  "dependencies": {
    "@web-loom/api-core": "*",
    "@web-loom/api-shared": "*",
    "drizzle-orm": "^0.36.4",
    "@neondatabase/serverless": "^0.10.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "5.9.2",
    "vitest": "^2.1.8"
  }
}
